    "ease-out": {
      "$type": "cubicBezier",
      "$value": [0, 0, 0.2, 1],
      "$description": "Entrances"
    },
    "ease-in-out": {
      "$type": "cubicBezier",
      "$value": [0.4, 0, 0.2, 1],
      "$description": "Standard transitions"
    },
    "spring": {
      "$type": "cubicBezier",
      "$value": [0.175, 0.885, 0.32, 1.275],
      "$description": "Playful overshoot"
    }
  },
