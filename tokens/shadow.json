{
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0",
        "color": "rgb(0 0 0 / 0.05)"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-1px",
          "color": "rgb(0 0 0 / 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "2px",
          "blur": "4px",
          "spread": "-2px",
          "color": "rgb(0 0 0 / 0.1)"
        }
      ]
    },
    "lg": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "10px",
          "blur": "15px",
          "spread": "-3px",
          "color": "rgb(0 0 0 / 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-4px",
          "color": "rgb(0 0 0 / 0.1)"
        }
      ]
    },
    "xl": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "20px",
          "blur": "25px",
          "spread": "-5px",
          "color": "rgb(0 0 0 / 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "8px",
          "blur": "10px",
          "spread": "-6px",
          "color": "rgb(0 0 0 / 0.1)"
        }
      ]
    }
  }
}
