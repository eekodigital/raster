{
  "name": "@eekodigital/raster",
  "version": "2.0.0",
  "description": "Raster — design system by Eeko Digital",
  "license": "MIT",
  "author": "Eeko Digital <hello@eeko.digital>",
  "repository": {
    "type": "git",
    "url": "https://github.com/eekodigital/raster"
  },
  "files": [
    "dist",
    "src/tokens",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./data-table": {
      "import": "./dist/data-table.mjs",
      "types": "./dist/data-table.d.mts"
    },
    "./tokens.css": "./src/tokens/tokens.css",
    "./primitives.css": "./src/tokens/tokens.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:tokens": "node --import tsx/esm style-dictionary.config.ts && pnpm exec vp check --fix src/tokens docs/src/styles && node --import tsx/esm scripts/merge-tokens.ts && pnpm exec vp check --fix tokens/tokens.json",
    "build": "pnpm build:tokens && tsdown",
    "dev": "pnpm build:tokens && concurrently -n lib,docs \"tsdown --watch\" \"pnpm --filter @eekodigital/raster-docs dev\"",
    "dev:lib": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "vp lint",
    "check": "vp check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "axe-core": "^4.11.4",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "style-dictionary": "^5.4.0",
    "topojson-client": "^3.1.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.21",
    "vitest": "^4.1.6",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-table": {
      "optional": true
    },
    "topojson-client": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0"
}
